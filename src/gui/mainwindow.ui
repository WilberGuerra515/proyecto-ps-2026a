<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Linux System Controller - C/Qt Admin</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout">
    <property name="spacing">
     <number>0</number>
    </property>
    <property name="leftMargin">
     <number>0</number>
    </property>
    <property name="topMargin">
     <number>0</number>
    </property>
    <property name="rightMargin">
     <number>0</number>
    </property>
    <property name="bottomMargin">
     <number>0</number>
    </property>
    <item>
     <widget class="QTabWidget" name="mainTabWidget">
      <property name="currentIndex">
       <number>0</number>
      </property>
      
      <!-- MÓDULO 1: TAREAS -->
      <widget class="QWidget" name="tabTasks">
       <attribute name="title">
        <string>Tareas (Módulo 1)</string>
       </attribute>
       <layout class="QVBoxLayout" name="layoutTasks">
        <item>
         <widget class="QTreeWidget" name="processTreeWidget"/>
        </item>
        <item>
         <layout class="QHBoxLayout" name="layoutTasksButtons">
          <item>
           <widget class="QPushButton" name="btnRefresh">
            <property name="text">
             <string>Actualizar Lista</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="spacerTasks">
            <property name="orientation">
             <enum>Qt::Horizontal</enum>
            </property>
           </spacer>
          </item>
          <item>
           <widget class="QPushButton" name="btnStop">
            <property name="text">
             <string>Suspender (SIGSTOP)</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnCont">
            <property name="text">
             <string>Reanudar (SIGCONT)</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnKill">
            <property name="text">
             <string>Terminar (SIGKILL)</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>

      <!-- MÓDULO 2: ARCHIVOS -->
      <widget class="QWidget" name="tabFiles">
       <attribute name="title">
        <string>Archivos (Módulo 2)</string>
       </attribute>
       <layout class="QHBoxLayout" name="layoutFilesMain">
        <!-- Panel Izquierdo: Explorador -->
        <item>
         <layout class="QVBoxLayout" name="layoutFilesLeft">
          <item>
           <widget class="QLabel" name="lblCurrentPath">
            <property name="text">
             <string>Ruta Actual:</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QLineEdit" name="txtCurrentPath">
            <property name="text">
             <string>/</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QTreeWidget" name="fileTreeWidget"/>
          </item>
         </layout>
        </item>
        <!-- Panel Derecho: Buscador -->
        <item>
         <layout class="QVBoxLayout" name="layoutFilesRight">
          <item>
           <widget class="QLabel" name="lblSearch">
            <property name="text">
             <string>Búsqueda Recursiva Asíncrona:</string>
            </property>
           </widget>
          </item>
          <item>
           <layout class="QHBoxLayout" name="layoutSearchInput">
            <item>
             <widget class="QLineEdit" name="txtSearchFile">
              <property name="placeholderText">
               <string>Nombre del archivo a buscar...</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="btnSearchFile">
              <property name="text">
               <string>Buscar</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item>
           <widget class="QProgressBar" name="searchProgressBar">
            <property name="visible">
             <bool>false</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QListWidget" name="lstSearchResults"/>
          </item>
         </layout>
        </item>
       </layout>
      </widget>

      <!-- MÓDULO 3: CONSOLA DE COMANDOS -->
      <widget class="QWidget" name="tabCommands">
       <attribute name="title">
        <string>Comandos (Módulo 3)</string>
       </attribute>
       <layout class="QVBoxLayout" name="layoutCommands">
        <item>
         <widget class="QPlainTextEdit" name="txtConsoleOutput">
          <property name="readOnly">
           <bool>true</bool>
          </property>
          <property name="styleSheet">
           <string notr="true">background-color: #000000; color: #00FF00; font-family: 'Monospace', 'Courier New';</string>
          </property>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="layoutCommandInput">
          <item>
           <widget class="QLineEdit" name="txtCommandInput">
            <property name="placeholderText">
             <string>Escribe un comando (ej: ping -c 4 google.com, ls -la)...</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnSendCommand">
            <property name="text">
             <string>Ejecutar</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="btnTerminateCommand">
            <property name="text">
             <string>Detener</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>

      <!-- MÓDULO 4: GESTOR DE RESPALDOS -->
      <widget class="QWidget" name="tabBackups">
       <attribute name="title">
        <string>Respaldos (Módulo 4)</string>
       </attribute>
       <layout class="QVBoxLayout" name="layoutBackups">
        <item>
         <layout class="QFormLayout" name="formLayoutBackups">
          <property name="verticalSpacing">
           <number>12</number>
          </property>
          <item row="0" column="0">
           <widget class="QLabel" name="lblSrcDir">
            <property name="text">
             <string>Directorio Origen a respaldar:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="QLineEdit" name="txtSrcDir">
            <property name="text">
             <string>/home/Dieguito/pruebaQT</string>
            </property>
           </widget>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="lblDestDir">
            <property name="text">
             <string>Directorio Destino (Donde se guardará):</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="QLineEdit" name="txtDestDir">
            <property name="text">
             <string>/home/Dieguito</string>
            </property>
           </widget>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="lblBackupName">
            <property name="text">
             <string>Nombre del Archivo Final (.tar.gz):</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <widget class="QLineEdit" name="txtBackupName">
            <property name="placeholderText">
             <string>respaldo_proyecto_final</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <spacer name="spacerBackups">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeType">
           <enum>QSizePolicy::Fixed</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>10</height>
           </size>
          </property>
         </spacer>
        </item>
        <item>
         <widget class="QPushButton" name="btnCreateBackup">
          <property name="text">
           <string>Generar Respaldo Tarball (.tar.gz)</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QProgressBar" name="backupProgressBar">
          <property name="value">
           <number>0</number>
          </property>
          <property name="visible">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QTextEdit" name="txtBackupLog">
          <property name="readOnly">
           <bool>true</bool>
          </property>
          <property name="placeholderText">
           <string>Historial de operaciones de respaldo...</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>

      <!-- MÓDULO 5: MONITOR DE RECURSOS -->
      <widget class="QWidget" name="tabSystemMonitor">
       <attribute name="title">
        <string>Monitor (Módulo 5)</string>
       </attribute>
       <layout class="QVBoxLayout" name="layoutMonitor">
        <property name="spacing">
         <number>15</number>
        </property>
        <item>
         <widget class="QGroupBox" name="groupRAM">
          <property name="title">
           <string>Memoria RAM Dinámica</string>
          </property>
          <layout class="QVBoxLayout" name="layoutRAM">
           <item>
            <widget class="QProgressBar" name="barRAM">
             <property name="value">
              <number>0</number>
             </property>
             <property name="format">
              <string>%v MB / %m MB (%p%)</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="lblRAMDetails">
             <property name="text">
              <string>Memoria Libre: Calculando...</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupCPU">
          <property name="title">
           <string>Carga del Sistema (Load Average)</string>
          </property>
          <layout class="QFormLayout" name="layoutCPU">
           <item row="0" column="0">
            <widget class="QLabel" name="lblLoad1">
             <property name="text">
              <string>Último minuto:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QLabel" name="valLoad1">
             <property name="text">
              <string>0.00</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="lblLoad5">
             <property name="text">
              <string>Últimos 5 minutos:</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QLabel" name="valLoad5">
             <property name="text">
              <string>0.00</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupUptime">
          <property name="title">
           <string>Estadísticas de Actividad</string>
          </property>
          <layout class="QHBoxLayout" name="layoutUptime">
           <item>
            <widget class="QLabel" name="lblUptimeText">
             <property name="text">
              <string>Tiempo encendido desde el último arranque:</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="valUptime">
             <property name="text">
              <string>00:00:00</string>
             </property>
             <property name="font">
              <font>
               <bold>true</bold>
              </font>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <spacer name="spacerMonitor">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>

    <!-- Pestaña restante en blanco (Placeholders) -->
      <widget class="QWidget" name="tabDownloads"><attribute name="title"><string>Descargas (Módulo 6)</string></attribute></widget>
     </widget>
    </item>
   </layout>
  </widget>
 </widget>
